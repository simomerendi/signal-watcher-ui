{
	"name": "signal-watcher-ui",
	"main": "dist/_worker.js",
	"compatibility_date": "2025-01-01",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": "dist"
	},
	"d1_databases": [
		{
			"binding": "AUTH_DB",
			"database_name": "signal-watcher-auth",
			"database_id": "<set after: wrangler d1 create signal-watcher-auth>"
		}
	],
	"vars": {
		"BETTER_AUTH_URL": "http://localhost:4321",
		"SIGNAL_WATCHER_URL": "http://localhost:8787"
	}
}
