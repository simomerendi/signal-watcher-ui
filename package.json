{
	"name": "signal-watcher-ui",
	"version": "0.1.0",
	"description": "Astro UI for signal-watcher (single-tenant)",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "wrangler dev",
		"deploy": "astro build && wrangler deploy",
		"cf-typegen": "wrangler types --env-interface Env",
		"auth:generate": "better-auth generate --config src/lib/auth.generate.ts --output src/db/schema.ts",
		"migrate:generate": "drizzle-kit generate",
		"migrate:apply:local": "wrangler d1 migrations apply signal-watcher-auth --local",
		"migrate:apply:remote": "wrangler d1 migrations apply signal-watcher-auth --remote",
		"typecheck": "astro check",
		"test": "vitest run"
	},
	"packageManager": "pnpm@10.29.1",
	"dependencies": {
		"@astrojs/cloudflare": "^12.6.12",
		"@astrojs/react": "^4.4.2",
		"@astrojs/tailwind": "^5.1.4",
		"@better-auth/api-key": "^1.0.1",
		"@better-auth/drizzle-adapter": "^1.5.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"astro": "^5.18.0",
		"better-auth": "^1.5.2",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.7.7",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwindcss": "^3.4.17"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.6",
		"@better-auth/cli": "^1.0.6",
		"@cloudflare/workers-types": "^4.20250429.0",
		"@types/node": "^25.3.3",
		"drizzle-kit": "^0.31.9",
		"typescript": "~5.9.3",
		"vitest": "^3.1.3",
		"wrangler": "^4.69.0"
	}
}
